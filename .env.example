# ============================================================
#  Configuracion del feed real del Mundial 2026
# ============================================================
#
#  1) Registrate GRATIS en: https://www.football-data.org/client/register
#  2) Copia tu token y pegalo abajo en FOOTBALL_DATA_TOKEN
#  3) Copia este archivo como  .env   (sin el .example)
#  4) npm install  &&  npm start
#
#  Sin token, el servidor igual levanta y el cliente usa la
#  simulacion automaticamente (modo demo).
# ------------------------------------------------------------

# Token de football-data.org (dejalo vacio para modo simulacion)
FOOTBALL_DATA_TOKEN=

# Codigo de la competicion (WC = Copa del Mundo)
COMPETITION=WC

# Puerto del servidor
PORT=3000

# Cada cuantos ms consulta la API (free tier: 10 req/min, no bajar de 15000)
POLL_MS=20000
